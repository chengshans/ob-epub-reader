{
  "name": "ob-epub-reader",
  "version": "1.3.4",
  "description": "EPUB reader with highlights, margin notes, excerpts, and AI integration.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "release": "node esbuild.config.mjs production && node scripts/package-release.mjs",
    "release:publish": "node scripts/create-gitee-release.mjs",
    "postinstall": "patch-package",
    "lint": "eslint src"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "epub"
  ],
  "author": "chengshans",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chengshans/ob-epub-reader.git"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "patch-package": "^8.0.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "esbuild": "^0.28.0"
  }
}
